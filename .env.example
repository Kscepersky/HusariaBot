# Token bota z Discord Developer Portal
DISCORD_TOKEN=twoj-token-tutaj

# Client ID bota (Application ID z Developer Portal)
CLIENT_ID=twoj-client-id-tutaj

# ID serwera do testowania (opcjonalne — guild commands rejestrują się natychmiast)
GUILD_ID=id-twojego-serwera

# Role IDs (prawy przycisk na roli w Discordzie → Kopiuj ID)
ADMIN_ROLE_ID=id-roli-admin
MODERATOR_ROLE_ID=id-roli-moderator

# Category IDs (prawy przycisk na kategorii kanałów → Kopiuj ID)
SUPPORT_CATEGORY_ID=id-kategorii-ticketow

# ── Dashboard OAuth2 (Discord Developer Portal → OAuth2 → General) ─────────
# Client Secret (zakładka OAuth2 → Client Secret)
DISCORD_CLIENT_SECRET=twoj-client-secret-tutaj

# Redirect URI — musi być dodany w Developer Portal → OAuth2 → Redirects
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# Port na którym działa dashboard (domyślnie 3000)
DASHBOARD_PORT=3000

# Tajny klucz sesji — minimum 32 losowe znaki, np. wygeneruj: openssl rand -hex 32
DASHBOARD_SESSION_SECRET=zmien-mnie-na-losowy-string-min-32-znaki
