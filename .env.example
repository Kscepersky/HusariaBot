# Token bota z Discord Developer Portal
DISCORD_TOKEN=twoj-token-tutaj

# Client ID bota (Application ID z Developer Portal)
CLIENT_ID=twoj-client-id-tutaj

# ID serwera do testowania (opcjonalne — guild commands rejestrują się natychmiast)
GUILD_ID=id-twojego-serwera

# Role IDs (prawy przycisk na roli w Discordzie → Kopiuj ID)
ADMIN_ROLE_ID=id-roli-admin
MODERATOR_ROLE_ID=id-roli-moderator

# Category IDs (prawy przycisk na kategorii kanałów → Kopiuj ID)
SUPPORT_CATEGORY_ID=id-kategorii-ticketow

# Temporary voice channels
# Kanał voice, którego wejście tworzy prywatny kanał użytkownika
VOICE_TRIGGER_CHANNEL_ID=id-kanalu-trigger-voice

# Kategoria, w której bot tworzy tymczasowe kanały voice
VOICE_CATEGORY_ID=id-kategorii-voice

# ── Dashboard OAuth2 (Discord Developer Portal → OAuth2 → General) ─────────
# Client Secret (zakładka OAuth2 → Client Secret)
DISCORD_CLIENT_SECRET=twoj-client-secret-tutaj

# Redirect URI — musi być dodany w Developer Portal → OAuth2 → Redirects
DISCORD_REDIRECT_URI=http://localhost:3000/auth/discord/callback

# Port na którym działa dashboard (domyślnie 3000)
DASHBOARD_PORT=3000

# Opcjonalnie: ustaw 0 żeby wyłączyć logi developerskie dashboardu
DEV_LOGS=1

# Publiczny URL dashboardu używany przez komendę /dashboard
# Przykład lokalnie: http://localhost:3000
DASHBOARD_BASE_URL=http://localhost:3000

# API key do PandaScore (wykorzystywany przez zakładkę Baza meczów G2)
PANDASCORE_API_KEY=twoj-pandascore-api-key

# Opcjonalnie: ustaw 0 żeby wyłączyć heartbeat/logi developerskie bota
BOT_DEV_LOGS=1

# Tajny klucz sesji — minimum 32 losowe znaki, np. wygeneruj: openssl rand -hex 32
DASHBOARD_SESSION_SECRET=zmien-mnie-na-losowy-string-min-32-znaki

# Opcjonalnie: ścieżka do pliku SQLite z sesjami dashboardu
DASHBOARD_SESSION_DB_PATH=

# Opcjonalnie: czas życia sesji dashboardu w godzinach
DASHBOARD_SESSION_TTL_HOURS=24

# Opcjonalnie: ustaw 1 gdy aplikacja działa za reverse proxy
DASHBOARD_TRUST_PROXY=0

# Opcjonalnie: limity ruchu dashboardu
DASHBOARD_RATE_LIMIT_WINDOW_MS=900000
DASHBOARD_RATE_LIMIT_MAX=240
DASHBOARD_AUTH_RATE_LIMIT_WINDOW_MS=900000
DASHBOARD_AUTH_RATE_LIMIT_MAX=30
DASHBOARD_MUTATION_RATE_LIMIT_WINDOW_MS=60000
DASHBOARD_MUTATION_RATE_LIMIT_MAX=80
