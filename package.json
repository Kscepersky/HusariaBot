{
  "name": "husaria-bot",
  "version": "1.0.0",
  "description": "HusariaBot — Discord bot w TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npx tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "deploy": "npx tsx src/deploy-commands.ts",
    "clear-global": "npx tsx src/clear-global-commands.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "dashboard": "npx tsx src/dashboard/index.ts",
    "dashboard:dev": "npx tsx watch src/dashboard/index.ts"
  },
  "keywords": [],
  "license": "ISC",
  "dependencies": {
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
